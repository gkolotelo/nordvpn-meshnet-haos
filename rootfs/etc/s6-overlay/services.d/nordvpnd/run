#!/usr/bin/with-contenv bash
# s6 service: Start the NordVPN daemon (required for all operations)
# This runs continuously and is supervised by s6

set -euo pipefail

echo "Starting NordVPN daemon..."

# Start the daemon in the background
nordvpnd &
DAEMON_PID=$!

echo "NordVPN daemon started (PID: $DAEMON_PID)"

# Wait for daemon to be ready
for i in $(seq 1 30); do
    if nordvpn status >/dev/null 2>&1; then
        echo "NordVPN daemon is ready"
        break
    fi
    sleep 1
done

# Keep the process alive (s6 will restart if it crashes)
wait $DAEMON_PID
